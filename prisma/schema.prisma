generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum HostType {
  MINI_PC
  VPS
  CUSTOM
}

model Host {
  id        String           @id @default(cuid())
  name      String
  type      HostType
  variants  HostVariant[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model HostVariant {
  id          String  @id @default(cuid())
  name        String
  cpuCores    Int
  memoryRamGb Float
  hostId   String
  host     Host @relation(fields: [hostId], references: [id], onDelete: Cascade)
}

model App {
  id                 String      @id @default(cuid())
  name               String
  category           String
  minCPU             Float
  recommendedCPU     Float
  minRAM             Float
  recommendedRAM     Float
  isCloudRecommended Boolean     @default(true)
  description        String?
  longDescription    String?
  officialUrl        String?
  cubepathUrl        String?
  dockerRegistryUrl  String?
  appBundles         AppBundle[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model AppBundle {
  id          String    @id @default(cuid())
  name        String
  description String?
  apps    App[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
