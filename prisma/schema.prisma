generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum MachineType {
  MINI_PC
  VPS
  CUSTOM
}

model Machine { 
  id        String   @id @default(cuid())
  name      String
  type      MachineType
  variants  MachineVariant[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MachineVariant {
  id          String   @id @default(cuid())
  name        String
  cpuCores    Int
  memoryRamGb Float
  machineId   String
  machine     Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
}

model Service {
  id                 String   @id @default(cuid())
  name               String
  category           String
  minCPU             Float
  recommendedCPU     Float
  minRAM             Float
  recommendedRAM     Float
  isCloudRecommended Boolean  @default(true)
  description        String?
  longDescription    String?
  officialUrl        String?
  cubepathUrl        String?
  dockerRegistryUrl  String?
  appBundles         AppBundle[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AppBundle {
  id          String    @id @default(cuid())
  name        String
  description String?
  services    Service[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
