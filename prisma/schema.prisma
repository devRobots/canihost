// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Machine {
  id             String   @id @default(cuid())
  name           String
  type           String   // 'MINI_PC' | 'VPS' | 'CUSTOM'
  brand          String?
  targetAudience String?  // para quien esta destinado
  useCases       String?  // para que puede servir
  specialTech    String?  // tecnologias especiales
  technicalSpecs String?  // requisitos tecnicos
  variants       MachineVariant[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model MachineVariant {
  id          String   @id @default(cuid())
  name        String   // e.g. "832", "1664"
  cpuCores    Float
  memoryRamGb Float
  machineId   String
  machine     Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
}

model Service {
  id                    String   @id @default(cuid())
  name                  String
  category              String
  minCPU                Float    // Minimum Cores required
  recommendedCPU        Float    // Recommended Cores for optimal use
  minRAM                Float    // Minimum RAM required in GB
  recommendedRAM        Float    // Recommended RAM for optimal use
  isCloudRecommended    Boolean  @default(true)
  description           String?  // Short description
  longDescription       String?  // Extended details for modals
  officialUrl           String?
  cubepathUrl           String?
  dockerRegistryUrl     String?
  minRequirements       String?  // requisitos minimos
  recRequirements       String?  // requisitos recomendados
  appBundles            AppBundle[] // Implicit m2m
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AppBundle {
  id          String    @id @default(cuid())
  name        String
  description String?
  services    Service[] // Implicit m2m
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
